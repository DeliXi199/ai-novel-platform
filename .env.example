APP_NAME=AI Novel Platform MVP
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1

POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=novel_user
POSTGRES_PASSWORD=novel_password
POSTGRES_DB=novel_db
DATABASE_URL=postgresql+psycopg2://novel_user:novel_password@127.0.0.1:5432/novel_db

# 仅支持 openai | deepseek | groq，不再支持 mock 静默兜底
LLM_PROVIDER=deepseek

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_OUTPUT_TOKENS=4000
OPENAI_CHAPTER_MAX_OUTPUT_TOKENS=1500

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=120
DEEPSEEK_MAX_OUTPUT_TOKENS=4000
DEEPSEEK_CHAPTER_MAX_OUTPUT_TOKENS=2200

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TIMEOUT_SECONDS=120
GROQ_MAX_OUTPUT_TOKENS=4000
GROQ_CHAPTER_MAX_OUTPUT_TOKENS=1800

CHAPTER_TARGET_WORDS=1500
CHAPTER_HARD_MIN_VISIBLE_CHARS=900
CHAPTER_MIN_VISIBLE_CHARS=1200
CHAPTER_SIMILARITY_THRESHOLD=0.76
CHAPTER_CONTEXT_MODE=light
CHAPTER_RECENT_SUMMARY_LIMIT=2
CHAPTER_LAST_EXCERPT_CHARS=500
CHAPTER_LIVE_HOOK_LIMIT=6
CHAPTER_RECENT_SUMMARY_CHARS=120
CHAPTER_PROMPT_MAX_CHARS=7600
CHAPTER_DRAFT_MAX_ATTEMPTS=4
CHAPTER_TOO_SHORT_RETRY_ATTEMPTS=3
CHAPTER_TOO_SHORT_RETRY_DELAY_MS=1800
CHAPTER_TAIL_FIX_ATTEMPTS=2
CHAPTER_TAIL_FIX_DELAY_MS=900
CHAPTER_SUMMARY_MAX_OUTPUT_TOKENS=320
# auto = 先尝试模型摘要，失败后退回启发式摘要
# llm = 始终走模型摘要，失败直接报错
# heuristic = 始终走本地启发式摘要
CHAPTER_SUMMARY_MODE=auto
LLM_CALL_MIN_INTERVAL_MS=1200
LLM_TRACE_LIMIT=16
RETURN_DRAFT_PAYLOAD_IN_META=false

CHAPTER_PROBE_TARGET_MIN_VISIBLE_CHARS=1000
CHAPTER_PROBE_TARGET_MAX_VISIBLE_CHARS=1500
CHAPTER_PROGRESS_TARGET_MIN_VISIBLE_CHARS=1400
CHAPTER_PROGRESS_TARGET_MAX_VISIBLE_CHARS=2200
CHAPTER_TURNING_POINT_TARGET_MIN_VISIBLE_CHARS=1800
CHAPTER_TURNING_POINT_TARGET_MAX_VISIBLE_CHARS=2600

BOOTSTRAP_INITIAL_CHAPTERS=0
GLOBAL_OUTLINE_ACTS=4
ARC_OUTLINE_SIZE=5
ARC_PREFETCH_THRESHOLD=0
