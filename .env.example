APP_NAME=AI Novel Platform MVP
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=novel_user
POSTGRES_PASSWORD=novel_password
POSTGRES_DB=novel_db
DATABASE_URL=postgresql+psycopg2://novel_user:novel_password@127.0.0.1:5432/novel_db

# 仅支持 openai | deepseek | groq，不再支持 mock 静默兜底
LLM_PROVIDER=deepseek
BOOTSTRAP_LLM_PROVIDER=
BOOTSTRAP_MODEL=deepseek-chat
BOOTSTRAP_TIMEOUT_SECONDS=180

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.4
OPENAI_REASONING_EFFORT=medium
OPENAI_TIMEOUT_SECONDS=240
OPENAI_MAX_OUTPUT_TOKENS=4000
OPENAI_CHAPTER_MAX_OUTPUT_TOKENS=1500

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=240
DEEPSEEK_MAX_OUTPUT_TOKENS=4000
DEEPSEEK_CHAPTER_MAX_OUTPUT_TOKENS=2400

# Groq
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TIMEOUT_SECONDS=240
GROQ_MAX_OUTPUT_TOKENS=4000
GROQ_CHAPTER_MAX_OUTPUT_TOKENS=1800

